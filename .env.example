# Copy to .env and fill in. .env is git-ignored.
# All values shown are sensible defaults for local development.

# === Alpaca (https://alpaca.markets) ===
ALPACA_API_KEY=your_paper_key_here
ALPACA_API_SECRET=your_paper_secret_here

# Paper trading is the default. To go live you must set BOTH:
#   ALPACA_PAPER=false
#   ALPACA_LIVE_CONFIRM=YES_I_MEAN_IT
ALPACA_PAPER=true
ALPACA_LIVE_CONFIRM=

# === Storage ===
# SQLite (default; works for local home server):
DATABASE_URL=sqlite:///data/trading.db
# Postgres (uncomment if running `make up-pg`):
# DATABASE_URL=postgresql+psycopg2://trader:trader_local_only@postgres:5432/trading

# === Capital allocation + risk ===
ACCOUNT_STARTING_EQUITY=100000
PER_BOT_CAP=25000
PER_POSITION_PCT=0.05
GLOBAL_MAX_DRAWDOWN=0.10

# Per-bot drawdown circuit breaker (auto-pauses a bot whose 30-day DD breaches).
PER_BOT_MAX_DRAWDOWN=0.15

# === Bot enablement ===
ENABLED_BOTS=momentum,mean_reversion

# === Universe overrides ===
MOMENTUM_UNIVERSE=SPY,QQQ,AAPL,MSFT,NVDA,AMZN,META,GOOGL,TSLA
MEAN_REVERSION_UNIVERSE=SPY,QQQ,IWM,DIA
CRYPTO_UNIVERSE=BTC/USD,ETH/USD

# === Dashboard auth ===
# Set to gate the dashboard. If empty, dashboard is open + warns.
DASHBOARD_PASSWORD=

# === Alerting (optional) ===
# Set any/all to receive alerts. Leave empty to disable that channel.
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# === Optional integrations ===
QUIVER_API_KEY=
NEWSAPI_KEY=

# === Research agent (optional — install with: pip install -e ".[research]") ===
# LLM (required to use the research agent)
GEMINI_API_KEY=
RESEARCH_MODEL=gemini-2.5-pro
RESEARCH_FAST_MODEL=gemini-2.5-flash
RESEARCH_EMBED_MODEL=text-embedding-004
# General web search — https://tavily.com (1000 free searches/mo)
TAVILY_API_KEY=
# Reddit — https://www.reddit.com/prefs/apps  (create a "script" app, free)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=trading-bot-research/0.1
# GitHub PAT (optional — public-only scopes; raises rate limits)
GITHUB_TOKEN=
# YouTube Data API (optional — for keyword search; transcripts work without it)
YOUTUBE_API_KEY=
# Apify (optional — for X / TikTok / Instagram in v2)
APIFY_TOKEN=
# Pydantic Logfire (optional — agent observability)
LOGFIRE_TOKEN=

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=auto   # auto | pretty | json

# === Ports (override if any conflict on your machine) ===
# HEALTHZ_PORT=8081
# API_PORT=8000
# WEB_PORT=3000
