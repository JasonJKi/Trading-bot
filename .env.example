# Alpaca paper account (https://alpaca.markets/) — free
ALPACA_API_KEY=your_paper_key_here
ALPACA_API_SECRET=your_paper_secret_here

# Paper trading is the default. To go live, set BOTH of these:
#   ALPACA_PAPER=false
#   ALPACA_LIVE_CONFIRM=YES_I_MEAN_IT
ALPACA_PAPER=true
ALPACA_LIVE_CONFIRM=

# Storage (SQLite file path)
DATABASE_URL=sqlite:///data/trading.db

# Capital allocation
ACCOUNT_STARTING_EQUITY=100000
PER_BOT_CAP=25000
PER_POSITION_PCT=0.05

# Global drawdown circuit breaker (fraction of starting equity)
GLOBAL_MAX_DRAWDOWN=0.10

# Optional: external data providers
QUIVER_API_KEY=
NEWSAPI_KEY=

# Bot enable/disable (comma-separated)
ENABLED_BOTS=momentum,mean_reversion

# Universe overrides (comma-separated)
MOMENTUM_UNIVERSE=SPY,QQQ,AAPL,MSFT,NVDA,AMZN,META,GOOGL,TSLA
MEAN_REVERSION_UNIVERSE=SPY,QQQ,IWM,DIA
CRYPTO_UNIVERSE=BTC/USD,ETH/USD

# Logging
LOG_LEVEL=INFO
